# SENTINEL-X Environment Configuration
# Copy this to .env and fill in your values

# ── Node Identity ─────────────────────────────────────────────────────────────
SENTINEL_NODE_ID=sentinel_node_1

# ── OS Override (auto-detected if not set) ────────────────────────────────────
# SENTINEL_OS=linux

# ── Dry Run (set to 1 to disable DB/blockchain) ───────────────────────────────
# SENTINEL_DRY_RUN=1

# ── Database ──────────────────────────────────────────────────────────────────
MILBASTER_DB=sentinel.db
MILBASTER_KEYSTORE=keystore

# ── Blockchain (Sepolia testnet) ──────────────────────────────────────────────
# Get from: https://infura.io or https://alchemy.com
INFURA_SEPOLIA_URL=your_infura_sepolia_rpc_url

# Your Ethereum wallet private key (hex, no 0x prefix)
PRIVATE_KEY=your_private_key_here

# Your Ethereum wallet address
ACCOUNT=your_account_address_here

# Deployed MILBASTERLog contract address on Sepolia
CONTRACT_ADDR=your_contract_address_here

# ── Anchor Settings ───────────────────────────────────────────────────────────
ANCHOR_BATCH_SIZE=32
ANCHOR_INTERVAL=60
